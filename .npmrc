# ─── Peer dependencies ────────────────────────────────────────────────────────
# Never auto-install peer deps — keeps installs deterministic.
auto-install-peers=false

# Warn on peer dep conflicts but never fail the install.
strict-peer-dependencies=false

# ─── Engine checks ───────────────────────────────────────────────────────────
# Render may provision a patch version of Node 22 (e.g. 22.4.1) that
# doesn't exactly satisfy the "22.x" engines range check pnpm runs.
# Log the warning but never abort the install over it.
engine-strict=false
