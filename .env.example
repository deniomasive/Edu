# Moz-Gondza — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Render provides this automatically via the `fromDatabase` binding in render.yaml.
DATABASE_URL=postgresql://user:password@localhost:5432/mozgondza

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Secret key used for session signing (if applicable).
SESSION_SECRET=change-me-to-another-long-random-secret

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Port the API server listens on.
# Render sets this automatically for web services; use 10000 as the default.
PORT=10000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Full URL of the deployed frontend (no trailing slash).
# Used to configure CORS on the API server.
# Example: https://moz-gondza-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# Full URL of the deployed API server (no trailing slash).
# Passed to the browser so the frontend knows where to send API requests.
# Leave empty when frontend and backend share the same origin (e.g. local dev).
# Example: https://moz-gondza-api.onrender.com
VITE_API_URL=

# Base path for the frontend (use / unless deploying to a sub-path).
BASE_PATH=/
